# Copy this file to e2e/.env.e2e and fill in the values.
# (This file is named without a leading dot so the repo's permission rules
# allow committing it as a non-secret template; the working copy must be
# `e2e/.env.e2e`, which playwright.config.ts loads via dotenv.)

# Base URL for the test target. Defaults to http://localhost:3000.
# E2E_BASE_URL=http://localhost:3000
# E2E_PORT=3000

# Concurrent worker count. Accepts a number (`4`) or percentage (`50%`).
# Defaults to 2 in CI, 3 locally — see playwright.config.ts for rationale.
# E2E_WORKERS=3

# --- Next.js runtime env (forwarded to webServer) ---
# 'staging' disables AUTH_ENABLED and WHITELIST_OVERLAY_ENABLED feature flags.
NEXT_PUBLIC_ENVIRONMENT=staging

# Switchboard GraphQL endpoint. Tests fetch real data from staging.
NEXT_PUBLIC_SWITCHBOARD_URL=https://switchboard-staging.powerhouse.xyz/graphql

# Public Ethereum RPC. Used by wallet/address rendering.
NEXT_PUBLIC_ETH_MAINNET_RPC=https://ethereum-rpc.publicnode.com

# Whitelist overlay must be off for tests; otherwise a fixed overlay blocks UI.
NEXT_PUBLIC_SHOW_WHITELIST_OVERLAY=false

# Disable beforeunload prompt during purchase flow tests.
NEXT_PUBLIC_LEAVE_PAGE_GUARD_ENABLED=false

# Disable Zustand store persistence so each spec starts clean.
NEXT_PUBLIC_ENABLE_SERVICE_PURCHASE_STORE_PERSISTENCE=false

# --- Test data slugs ---
# Pinned in e2e/data/constants.ts. Update there if a staging entity changes.
